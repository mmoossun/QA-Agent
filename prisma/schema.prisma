// Prisma schema — SQLite (dev) / PostgreSQL (prod)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── User ────────────────────────────────────────────────────
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  projects  Project[]
  agentRuns AgentRun[]
  testRuns  TestRun[]
}

// ─── Project ─────────────────────────────────────────────────
model Project {
  id          String   @id @default(cuid())
  name        String
  url         String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId   String
  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  testRuns TestRun[]
  agentRuns AgentRun[]
  boards   QABoard[]
  issues   Issue[]
}

// ─── TestRun ─────────────────────────────────────────────────
model TestRun {
  id          String   @id @default(cuid())
  status      String   @default("pending") // pending | running | completed | failed
  mode        String   @default("chat")    // chat | agent
  inputPrompt String
  scenarios   String   // JSON array of QAScenario
  results     String?  // JSON array of TestResult
  summary     String?  // JSON summary
  score       Float?
  duration    Int?     // ms
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId String?
  project   Project?   @relation(fields: [projectId], references: [id])
  bugReports BugReport[]
}

// ─── BugReport ───────────────────────────────────────────────
model BugReport {
  id           String   @id @default(cuid())
  title        String
  severity     String   // critical | high | medium | low
  category     String   // selector | timing | logic | ui | security
  description  String
  steps        String   // JSON steps to reproduce
  expected     String
  actual       String
  screenshotUrl String?
  status       String   @default("open") // open | fixed | wontfix
  createdAt    DateTime @default(now())

  testRunId String
  testRun   TestRun @relation(fields: [testRunId], references: [id], onDelete: Cascade)
}

// ─── AgentRun ─────────────────────────────────────────────────
model AgentRun {
  id           String   @id @default(cuid())
  targetUrl    String
  loginEmail   String?
  status       String   @default("pending") // pending | exploring | generating | running | reporting | done | failed
  iteration    Int      @default(0)
  score        Float?
  scoreBefore  Float?
  scoreAfter   Float?
  exploration  String?  // JSON: site structure discovered
  scenarios    String?  // JSON: generated scenarios
  results      String?  // JSON: test results
  report       String?  // JSON: final QA report
  improvements String?  // JSON: suggested improvements
  commitHash   String?
  duration     Int?
  errorMsg     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id])
}

// ─── SavedReport ─────────────────────────────────────────────
model SavedReport {
  id               String   @id
  name             String
  savedAt          DateTime @default(now())
  createdAt        String
  targetUrl        String
  goal             String   @default("")
  status           String
  riskLevel        String
  passRate         Float
  stepCount        Int
  totalDurationMs  Int
  executiveSummary String
  findings         String   // JSON
  recommendations  String   // JSON
  testedFeatures   String   // JSON
  steps            String   // JSON
}

// ─── QA Board: Issue ─────────────────────────────────────────
// Web에서 직접 생성하거나 테스트 실행 결과에서 자동 생성되는 이슈
model Issue {
  id          String   @id @default(cuid())
  title       String
  description String?
  type        String   @default("bug")    // bug | design | content | accessibility | spec
  severity    String   @default("minor")  // critical | major | minor | trivial
  status      String   @default("open")   // open | in_progress | resolved | wont_fix
  source      String   @default("web")    // web | agent | sheets | api
  screenshotUrl String?
  targetUrl   String?
  stepToReproduce String?
  expectedResult  String?
  actualResult    String?
  tags        String?  // JSON string[]
  externalIds String?  // JSON { jira_id, notion_id, ... }
  resolvedAt  DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  projectId   String?
  project     Project?  @relation(fields: [projectId], references: [id])
  boardId     String?
  board       QABoard?  @relation(fields: [boardId], references: [id])
  comments    IssueComment[]
  history     IssueHistory[]
}

// ─── QA Board ────────────────────────────────────────────────
model QABoard {
  id          String   @id @default(cuid())
  name        String
  description String?
  targetUrl   String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  projectId   String?
  project     Project?  @relation(fields: [projectId], references: [id])
  issues      Issue[]
  shareLinks  SharedBoard[]
}

// ─── SharedBoard (공유 링크) ──────────────────────────────────
model SharedBoard {
  id           String   @id @default(cuid())
  publicToken  String   @unique @default(cuid())
  label        String?
  expiresAt    DateTime?
  viewCount    Int      @default(0)
  createdAt    DateTime @default(now())

  boardId      String
  board        QABoard  @relation(fields: [boardId], references: [id], onDelete: Cascade)
}

// ─── IssueComment ─────────────────────────────────────────────
model IssueComment {
  id        String   @id @default(cuid())
  content   String
  authorName String  @default("익명")
  createdAt DateTime @default(now())

  issueId   String
  issue     Issue    @relation(fields: [issueId], references: [id], onDelete: Cascade)
}

// ─── IssueHistory ─────────────────────────────────────────────
model IssueHistory {
  id        String   @id @default(cuid())
  field     String   // status | severity | assignee ...
  oldValue  String?
  newValue  String?
  createdAt DateTime @default(now())

  issueId   String
  issue     Issue    @relation(fields: [issueId], references: [id], onDelete: Cascade)
}

// ─── ImprovementHistory ─────────────────────────────────────
model ImprovementHistory {
  id          String   @id @default(cuid())
  iteration   Int
  scoreBefore Float
  scoreAfter  Float
  commitHash  String?
  commitMsg   String?
  changes     String   // JSON: what was changed
  issues      String   // JSON: issues found
  createdAt   DateTime @default(now())
}
